[run]
source = iam_guardian
omit =
    iam_guardian/init_db.py
    */tests/*
    */__pycache__/*
    iam_guardian/static/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
show_missing = True
skip_covered = False

[html]
directory = htmlcov
